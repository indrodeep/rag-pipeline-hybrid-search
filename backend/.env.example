# --- Required ---
# OpenAI API key used for embeddings (text-embedding-3-small),
# generation (gpt-4o), and LLM-as-judge calls (reranking, citation
# verification, completeness, eval grading).
OPENAI_API_KEY=sk-...

# --- Storage (defaults shown; paths are relative to the backend/ directory) ---
CHROMA_PERSIST_DIR=./data/chroma
BM25_PERSIST_DIR=./data/bm25
DOCUMENTS_DIR=./data/documents

# --- Logging ---
LOG_LEVEL=INFO

# --- Public demo guardrails (cap OpenAI spend from stranger traffic) ---
# Defaults shown. PUBLIC_DEMO_MODE=true rate-limits /v1/ask and locks document
# upload + the eval suite to the admin key. Set ADMIN_API_KEY and send it as the
# X-Admin-Key request header to bypass the limits and reach those endpoints.
# PUBLIC_DEMO_MODE=true
# ADMIN_API_KEY=
# RATE_LIMIT_PER_IP_DAILY=20
# RATE_LIMIT_GLOBAL_DAILY=300

# --- Optional overrides ---
# EMBEDDING_MODEL=text-embedding-3-small
# GENERATION_MODEL=gpt-4o
# JUDGE_MODEL=gpt-4o
# DEDUP_THRESHOLD=0.95
# RRF_K=60
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
